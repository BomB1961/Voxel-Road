# Unity (공식 권장 .gitignore 기반)

# Unity 자동 생성 폴더 (용량 크고 재생성 가능)
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Unity 미사용 (Collab은 구 버전)
/[Aa]ssets/AssetStoreTools*

# Visual Studio / Rider / VS Code
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity 빌드 아티팩트
*.apk
*.aab
*.ipa
*.unitypackage
*.app

# 크래시 리포트
sysinfo.txt

# 빌더 결과물
*.o
*.dll
*.exe

# 민감 정보
*.key
*.pem
*.p12
*.keystore
.env
.env.*
credentials.*

# 디버그 로그 (런타임 생성)
debug_filtered.log

# Unity 자동 복구 씬 (크래시 후 생성)
/[Aa]ssets/_Recovery/
/[Aa]ssets/_Recovery.meta

# Editor 설정 일부
/[Aa]ssets/StreamingAssets/aa.meta
/[Aa]ssets/StreamingAssets/aa/*

# Claude Code 로컬 설정
/.claude/
/[Aa]ssets/Screenshots/
/[Aa]ssets/Screenshots.meta
